# VERNEN™ API Configuration
# Copy to .env and fill in values

# Anthropic API (required for audit engine)
ANTHROPIC_API_KEY=sk-ant-...

# Stripe (optional — CashApp fallback if not set)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Server
PORT=3001

# Frontend URL (for Stripe return URLs)
FRONTEND_URL=https://vernen-legal.netlify.app
